\newtcolorbox{srccode}{
  enhanced, breakable,
  colback=white, colframe=black!20,
  left=4pt, right=4pt, top=2pt, bottom=2pt,
  boxrule=0.4pt,
  arc=0pt, outer arc=0pt
}

\newtcolorbox{outcode}{
  enhanced, breakable,
  colback=white, colframe=black!20,
  left=4pt, right=4pt, top=2pt, bottom=2pt,
  boxrule=0.4pt,
  arc=0pt, outer arc=0pt,
  fontupper=\small
}

\hypersetup{
  colorlinks=true,
  linkcolor=black,
  urlcolor=blue!60!black,
  citecolor=blue!60!black,
}
