{%- if base == "latex" %}
\usepackage{xcolor}
\usepackage{amsmath,amssymb}
\usepackage[normalem]{ulem}
\usepackage{fancyvrb}
\usepackage[most]{tcolorbox}
\usepackage{booktabs}
\usepackage{longtable}
\usepackage{microtype}

\newtcolorbox{srccode}{
  enhanced, breakable,
  colback=white, colframe=black!20,
  left=4pt, right=4pt, top=2pt, bottom=2pt,
  boxrule=0.4pt,
  arc=0pt, outer arc=0pt
}

\newtcolorbox{outcode}{
  enhanced, breakable,
  colback=white, colframe=black!20,
  left=4pt, right=4pt, top=2pt, bottom=2pt,
  boxrule=0.4pt,
  arc=0pt, outer arc=0pt,
  fontupper=\small
}

\hypersetup{
  colorlinks=true,
  linkcolor={{latex_linkcolor}},
  urlcolor={{latex_urlcolor}},
  citecolor={{latex_citecolor}},
}
