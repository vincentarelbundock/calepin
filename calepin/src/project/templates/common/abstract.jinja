{%- if abstract %}
{%- if base == "html" %}
<div class="abstract">
{{abstract}}
</div>
{%- elif base == "latex" %}
\begin{abstract}
{{abstract}}
\end{abstract}
{%- elif base == "typst" %}
#pad(x: 1cm)[
  #align(center)[#smallcaps[{{label_abstract}}]]
  #v(0.5em)
  #text(size: 9.5pt)[{{abstract}}]
]
{%- endif %}
{%- endif %}