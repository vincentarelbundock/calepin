{%- set env = fig_env | default("figure") -%}
{%- if base == "html" %}
<div class="figure" id="{{id}}" style="{{align_style}}">
{{children}}
{%- if caption %}
<p class="caption">{{caption}}</p>
{%- endif %}
</div>
{%- elif base == "latex" %}
\begin{{_lb}}{{env}}{{_rb}}{{fig_pos}}
{{align_style}}
{{children}}
{{caption_cmd}}
{{label}}
\end{{_lb}}{{env}}{{_rb}}
{%- elif base == "typst" %}
{%- if caption %}
#figure([
{{children}}
], caption: [{{caption}}]) {{label}}
{%- else %}
{{children}} {{label}}
{%- endif %}
{%- else %}
{{children}}
{%- if caption %}

*{{caption}}*
{%- endif %}
{%- endif %}