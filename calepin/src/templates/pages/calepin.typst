#set document(title: "{{plain_title}}", author: "{{author}}")
#set page(margin: 2.5cm)
#set text(size: 11pt)
#set par(justify: true, leading: 0.65em)
#set heading(numbering: "1.1")

{{preamble}}

#align(center)[
  #text(size: 17pt, weight: "bold")[{{title}}]
  #v(0.3em)
  {{subtitle_block}}
  #v(0.5em)
  {{author_block}}
  #v(0.3em)
  #text(size: 10pt, style: "italic")[{{date}}]
]

{{abstract_block}}
{{keywords_block}}
{{toc}}

{{body}}

{{appendix_block}}
