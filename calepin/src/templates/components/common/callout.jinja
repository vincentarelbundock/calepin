{%- if base == "html" %}
  {%- if collapse == "true" %}
<details class="callout callout-{{callout_type}} callout-{{appearance}}"{{id_attr}}>
<summary>{{header}}</summary>
<div class="callout-body">
{{children}}
</div>
</details>
  {%- else %}
<div class="callout callout-{{callout_type}} callout-{{appearance}}"{{id_attr}}>
<div class="callout-header">{{header}}</div>
<div class="callout-body">
{{children}}
</div>
</div>
  {%- endif %}
{%- elif base == "latex" %}
  {%- if callout_type == "note" %}
\begin{tcolorbox}[enhanced, breakable, colback=blue!5, colframe=blue!40,
  {%- elif callout_type == "tip" %}
\begin{tcolorbox}[enhanced, breakable, colback=green!5, colframe=green!40,
  {%- elif callout_type == "warning" %}
\begin{tcolorbox}[enhanced, breakable, colback=yellow!10, colframe=yellow!60!black,
  {%- elif callout_type == "caution" %}
\begin{tcolorbox}[enhanced, breakable, colback=red!5, colframe=red!40,
  {%- elif callout_type == "important" %}
\begin{tcolorbox}[enhanced, breakable, colback=violet!5, colframe=violet!40,
  {%- else %}
\begin{tcolorbox}[enhanced, breakable, colback=blue!5, colframe=blue!40,
  {%- endif %}
  left=4pt, right=4pt, top=4pt, bottom=4pt,
  boxrule=0pt, leftrule=3pt, arc=0pt, outer arc=0pt,
  title={{title}}, fonttitle=\bfseries]
{{children}}
\end{tcolorbox}
{%- elif base == "typst" %}
  {%- if callout_type == "note" %}
#block(fill: rgb("#dbeafe"), stroke: (left: 3pt + rgb("#3b82f6")), inset: (x: 10pt, y: 8pt), radius: 0pt, width: 100%)[
  {%- elif callout_type == "tip" %}
#block(fill: rgb("#dcfce7"), stroke: (left: 3pt + rgb("#22c55e")), inset: (x: 10pt, y: 8pt), radius: 0pt, width: 100%)[
  {%- elif callout_type == "warning" %}
#block(fill: rgb("#fef9c3"), stroke: (left: 3pt + rgb("#eab308")), inset: (x: 10pt, y: 8pt), radius: 0pt, width: 100%)[
  {%- elif callout_type == "caution" %}
#block(fill: rgb("#fee2e2"), stroke: (left: 3pt + rgb("#ef4444")), inset: (x: 10pt, y: 8pt), radius: 0pt, width: 100%)[
  {%- elif callout_type == "important" %}
#block(fill: rgb("#ede9fe"), stroke: (left: 3pt + rgb("#8b5cf6")), inset: (x: 10pt, y: 8pt), radius: 0pt, width: 100%)[
  {%- else %}
#block(fill: rgb("#dbeafe"), stroke: (left: 3pt + rgb("#3b82f6")), inset: (x: 10pt, y: 8pt), radius: 0pt, width: 100%)[
  {%- endif %}
  #text(weight: "bold")[{{header}}] \
  {{children}}
]
{%- else %}
> **{{header}}**
>
> {{children}}
{%- endif %}